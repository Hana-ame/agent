    if len(args) not in (1, 2):
        return "错误：write 需要 1 个参数：<相对路径>，或 2 个参数：<相对路径> force"
    
    path = ctx.validate_path(args[0])
    force = False
    if len(args) == 2:
        if args[1].lower() == "force":
