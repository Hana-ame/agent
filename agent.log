"""
git - 执行 Git 命令

用法：py utils.py git <git命令...>

在根目录执行指定的 Git 命令。
"""

import subprocess
import shlex

def run(ctx, args):
    if not args:
        return "错误：git 需要至少一个参数"
    cmd = ["git"] + args
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, cwd=ctx.root_path)
        output = result.stdout + result.stderr
        return output.strip() if output.strip() else "(无输出)"
    except Exception as e:
        return f"错误：执行 git 命令失败 - {e}"
