"""
core.py - 工具核心模块，提供上下文和路径验证
"""

import os

class Context:
    def __init__(self, root_path):
        self.root_path = root_path

    def validate_path(self, relative_path):
        """
        验证并返回相对于根目录的绝对路径
        """
        # 防止路径遍历攻击
        if '..' in relative_path or relative_path.startswith('/') or relative_path.startswith('\\'):
            raise ValueError(f"非法路径：{relative_path}")
        return os.path.join(self.root_path, relative_path)

def load_root_path():
    """
    从环境变量或当前目录加载根路径
    """
    root = os.getcwd()
    # 尝试从 .env 文件读取 ROOT_PATH
    env_path = os.path.join(root, '.env')
    try:
        with open(env_path, 'r', encoding='utf-8') as f:
            for line in f:
                if line.startswith('ROOT_PATH'):
                    root = line.strip().split('=', 1)[1].strip()
                    if root.startswith('"') and root.endswith('"'):
                        root = root[1:-1]
                    elif root.startswith("'") and root.endswith("'"):
                        root = root[1:-1]
                    break
    except FileNotFoundError:
        pass
    return os.path.abspath(root)

