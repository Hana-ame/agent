"""
replace - 替换文件中的文本

用法：py utils.py replace <相对路径> <旧文本> <新文本>

参数：
  <相对路径>  要修改的文件路径
  <旧文本>    要被替换的文本
  <新文本>    替换后的文本

注意：文本参数可以是包含空格的字符串，需要用引号括起来。
"""

def run(ctx, args):
    if len(args) < 3:
        return "错误：replace 需要 3 个参数：<相对路径> <旧文本> <新文本>"
    path = ctx.validate_path(args[0])
    old = args[1]
    new = " ".join(args[2:]) if len(args) > 3 else args[2]
    try:
        with open(path, "r", encoding="utf-8") as f:
            content = f.read()
        new_content = content.replace(old, new)
        with open(path, "w", encoding="utf-8") as f:
            f.write(new_content)
        return f"成功：已替换文件 {args[0]} 中的文本"
    except Exception as e:
        return f"错误：无法替换文件 {args[0]} 中的文本 - {e}"
```
没问题，使用了validate_path。

