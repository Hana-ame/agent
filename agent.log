"""

import sys
import importlib
import os

def show_help(tool_name=None):
    ... # 省略

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    command = sys.argv[1].lower()
    args = sys.argv[2:]

    if command == "help":
        if args:
            show_help(args[0])
        else:
