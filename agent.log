                    if result is not None:
                        results.append(f"第 {line_num} 行: {result}")
                    else:
                        results.append(f"第 {line_num} 行: 执行成功（无输出）")
                except Exception as e:
                    results.append(f"第 {line_num} 行: 执行出错 - {e}")
            else:
                # 忽略不以 py utils.py 开头的行
                # 可选择记录调试信息，此处忽略
                pass

        # 打印所有结果
        for res in results:
            print(res)
        sys.exit(0)

    # 命令行模式（有参数）
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    command = sys.argv[1].lower()
    args = sys.argv[2:]

    if command == "help":
        if args:
            show_help(args[0])
        else:
