+import asyncio
+import json
+import re
+import pathlib
+from typing import List, Dict, Optional, Any, Tuple
+
+try:
+    import websockets
+except ImportError:
+    print("请安装websockets: pip install websockets")
+    raise
+try:
+    import httpx
+except ImportError:
+    print("请安装httpx: pip install httpx")
+    raise
