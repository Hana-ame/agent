"""
memory - 长期记忆存储工具（SQLite版）

用法：py utils.py memory <子命令> [参数...]

子命令：
  set <键> <值>  存储键值对
  get <键>       获取值
  delete <键>    删除键
  list           列出所有键
  clear          清空所有记忆

记忆存储在根目录的 memory.db 文件中。
"""

import sqlite3
import os

DB_FILE = "memory.db"

def get_db_path(ctx):
    return os.path.join(ctx.root_path, DB_FILE)

def run(ctx, args):
    if not args:
        return "错误：memory 需要子命令"
    cmd = args[0].lower()
    db_path = get_db_path(ctx)

    conn = sqlite3.connect(db_path)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS memory
                 (key TEXT PRIMARY KEY, value TEXT)''')
    conn.commit()

    try:
        if cmd == "set" and len(args) >= 3:
            key = args[1]
            value = " ".join(args[2:])
            c.execute("INSERT OR REPLACE INTO memory (key, value) VALUES (?, ?)", (key, value))
            conn.commit()
            result = f"已设置: {key} = {value}"
        elif cmd == "get" and len(args) == 2:
            key = args[1]
            c.execute("SELECT value FROM memory WHERE key=?", (key,))
            row = c.fetchone()
            result = row[0] if row else f"键 '{key}' 不存在"
        elif cmd == "delete" and len(args) == 2:
            key = args[1]
            c.execute("DELETE FROM memory WHERE key=?", (key,))
            conn.commit()
            result = f"已删除键: {key}"
        elif cmd == "list":
            c.execute("SELECT key FROM memory ORDER BY key")
            rows = c.fetchall()
            result = "\n".join(row[0] for row in rows) if rows else "(空)"
        elif cmd == "clear":
            c.execute("DELETE FROM memory")
            conn.commit()
            result = "已清空所有记忆"
        else:
            result = f"错误：无效的子命令或参数。用法：\n{__doc__}"
    except Exception as e:
        result = f"错误：{e}"
    finally:
        conn.close()
    return result
```
使用了ctx.root_path构建db_path，没问题。

