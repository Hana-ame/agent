  - 目标路径的父目录必须存在，否则报错。

示例：
  py utils.py move file.txt newname.txt          # 重命名
  py utils.py move file.txt dir/                  # 移动到 dir/ 目录下
  py utils.py move dir1/ dir2/                    # 移动目录
"""

import os
import shutil
from pathlib import Path

def run(ctx, args):
    if len(args) != 2:
        return "错误：move 需要 2 个参数：<源路径> <目标路径>"

